<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_home_offline"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo_offline"
    tools:context=".OfflineHomeActivity">

    <LinearLayout
        android:id="@+id/contenedor_general"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        >

        <TextView
            android:id="@+id/offline_home_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SDHYBC"
            android:textColor="@color/texto_line"
            android:textSize="40sp"
            android:textStyle="bold"

            />

        <TextView
            android:id="@+id/offline_home_aviso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OFFLINE"
            android:textColor="@color/texto_line"
            android:textSize="20sp"
            android:textStyle="bold"

            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/offline_home_boton_salir"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:text="SALIR"
            app:backgroundTint="@color/fondo_line"
            android:textColor="@color/texto_line"
            android:textSize="20sp"
            android:textStyle="bold" />


    </LinearLayout>





</androidx.constraintlayout.widget.ConstraintLayout>