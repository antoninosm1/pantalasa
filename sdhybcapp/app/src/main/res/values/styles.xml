<resources>
    <style name="BarraStatus">
        <item name="android:background">@color/color_oscuro_neutral</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">1dp</item>
    </style>
    <style name="TextoStatus">
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/color_claro_neutral</item>
        <item name="android:textSize">12sp</item>
    </style>
    <style name="PantallaNeutralOscuro">
        <item name="android:background">@color/color_oscuro_neutral</item>
        <item name="android:textColor">@color/color_claro_neutral</item>
        <item name="android:padding">1dp</item>
    </style>
    <style name="TituloCentralPrincipalNeutralOscuro">
        <item name="android:background">@color/color_oscuro_neutral</item>
        <item name="android:textColor">@color/color_claro_neutral</item>
        <item name="android:textSize">40sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">4dp</item>
    </style>
    <style name="AvisoCentralNeutralOscuro">
        <item name="android:background">@color/color_oscuro_neutral</item>
        <item name="android:textColor">@color/color_claro_neutral</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">2dp</item>
    </style>
    <style name="AreaTituloPrincipal">
        <item name="android:gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">1dp</item>
    </style>
    <style name="TituloPrincipalNeutral">
        <item name="android:text">SDHYBC</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">2dp</item>
    </style>
    <style name="TituloPrincipalClaro">
        <item name="android:text">SDHYBC</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/color_claro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">2dp</item>
    </style>
    <style name="TituloPrincipalOscuro">
        <item name="android:text">SDHYBC</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/color_oscuro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">2dp</item>
    </style>
    <!-- Estilo para botón MENU CLARO -->
    <style name="ButtonMenuStyleClaro">
        <item name="android:textColor">@color/color_oscuro</item>
        <item name="android:backgroundTint">@color/color_claro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">88dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_margin">2dp</item>
    </style>
    <!-- Estilo para botón MENU OSCURO -->
    <style name="ButtonMenuStyleOscuro">
        <item name="android:textColor">@color/color_claro</item>
        <item name="android:backgroundTint">@color/color_oscuro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">88dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_margin">2dp</item>
    </style>
    <!-- Estilo diferenciado para botón SALIR -->
    <style name="ButtonMenuStyleSalir">
        <item name="android:text">SALIR</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/fondo_line</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">88dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:contentDescription">Salir de la aplicación</item>
    </style>
    <style name="AreaTituloPrograma">
        <item name="android:gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">1dp</item>
    </style>
    <style name="TituloProgramaNeutral">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">1dp</item>
    </style>
    <style name="TituloProgramaClaro">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/color_claro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">1dp</item>
    </style>
    <style name="TituloProgramaOscuro">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/color_oscuro</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">1dp</item>
    </style>
    <style name="AreaTrabajoOscuro">
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:backgroundTint">@color/color_oscuro</item>
        <item name="android:background">@color/color_oscuro</item>
        <item name="android:textColor">@color/color_claro</item>
        <item name="android:padding">10dp</item>
    </style>
    <style name="ButtonStyleOnline">
        <item name="android:textColor">@color/fondo_online</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ButtonStyleOffline">
        <item name="android:textColor">@color/fondo_offline</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:gravity">center</item>
    </style>


    <!-- Estilo base accesible para botones -->
    <style name="BaseButtonStyleAccessible">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:gravity">center</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <!-- Estilo para botones offline accesibles -->
    <style name="ButtonStyleOfflineAccessible" parent="BaseButtonStyleAccessible">
        <item name="android:textColor">@color/fondo_offline_accessible</item>
        <item name="android:backgroundTint">@color/texto_offline_accessible</item>
    </style>
    <style name="NoBackgroundButton">
        <item name="android:background">@null</item>
    </style>

</resources>



