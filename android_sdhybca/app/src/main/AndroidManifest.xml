<?xml version="1.0" encoding="utf-8"?>
<!--
    Ruta: sdhybca/app/src/main/AndroidManifest.xml
    Descripción: Punto de entrada principal con todas las actividades declaradas.
    Mantenido de los CÓDIGOS BASE:
    - Actividades existentes (MainActivity, LineActivity, OfflineHomeActivity)
    - Configuración original de themes y labels
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.pantalasa.sdhybca">

    <application
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.Sdhybc"
        tools:targetApi="31">

        <!-- Actividad principal (LAUNCHER) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Actividad para modo línea (sin intent-filter) -->
        <activity
            android:name=".LineActivity"
            android:exported="false" />

        <!-- Actividad para modo offline (sin intent-filter) -->
        <activity
            android:name=".OfflineHomeActivity"
            android:exported="false" />
    </application>
</manifest>
